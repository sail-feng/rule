 "dns": 
 {
   "servers": 
   [
     {"tag": "dns_direct", "type": "udp", "server": "218.2.2.2"},
     {"tag": "dns_domain", "type": "udp", "server": "1.1.1.1"},
     {"tag": "dns_proxy", "type": "tls", "server": "8.8.8.8", "detour": "🚀 节点选择"},
     {"tag": "dns_emby", "type": "tls", "server": "8.8.8.8", "detour": "📺 MyEmby"},
     {"tag": "dns_fakeip", "type": "fakeip", "inet4_range": "198.18.0.0/15","inet6_range": "fc00::/18"}
   ],
   "rules": 
   [
     {"clash_mode": "Direct", "action": "route", "server": "dns_direct"},
     {"clash_mode": "Global", "action": "route", "server": "dns_fakeip"},
     {"rule_set": "geosite-cn", "action": "route", "server": "dns_direct"},
     {"rule_set": "geosite-apple", "action": "route", "server": "dns_direct"},
     {"rule_set": ["geosite-onedrive","geosite-microsoft"], "action": "route", "server": "dns_domain"},
     {"domain_suffix": "emby.wtf", "action": "route", "server": "dns_emby"},
     {"query_type":["A","AAAA"], "action": "route", "server": "dns_fakeip", "rewrite_ttl": 1}
   ],
   "final": "dns_proxy",
   "strategy": "prefer_ipv4",
   "independent_cache": true
},

